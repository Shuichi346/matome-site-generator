# ============================================
# 2ch/5chまとめ風ジェネレーター 設定ファイル
# ============================================
# このファイルを settings.yaml にコピーして、
# APIキーを入力してください。
#
#   cp config/settings.yaml.example config/settings.yaml
#
# settings.yaml は .gitignore で除外されているため、
# APIキーがGitに含まれることはありません。
# ============================================

# APIキー設定
api_keys:
  openai: "sk-your-openai-key-here"       # OpenAI APIキー
  gemini: "your-gemini-api-key-here"       # Google Gemini APIキー
  openrouter: "sk-or-v1-your-key-here"     # OpenRouter APIキー

# ローカルサーバー設定
local_servers:
  ollama_base_url: "http://localhost:11434"

# Ollama thinking設定
# think: true  → thinking（推論）モードON
# think: false → thinking（推論）モードOFF
# 未指定またはnull → モデルのデフォルト動作
ollama:
  discussion_think: false    # 議論用のthinking設定
  summarizer_think: false    # まとめ用のthinking設定

# OpenRouter設定
openrouter:
  base_url: "https://openrouter.ai/api/v1"

# カスタムOpenAI互換プロバイダー設定
# OpenAI互換APIを提供する任意のサービスに接続するための設定です。
# 例: Together AI, Groq, Fireworks, 自社プロキシ等
custom_openai:
  base_url: ""          # 例: "https://api.together.xyz/v1"
  api_key: ""           # APIキー（不要なサービスは空欄または "none"）
  # モデル能力の設定（不明な場合はデフォルトのままで問題ありません）
  model_info:
    vision: false
    function_calling: false
    json_output: true
    structured_output: false

# デフォルトモデル設定
defaults:
  discussion_provider: "gemini"
  discussion_model: "gemini-3.1-flash-lite-preview"
  summarizer_provider: "gemini"
  summarizer_model: "gemini-3-flash-preview"
  wait_time_seconds: 1.0

# Web検索・URL取得設定
web_fetch:
  max_search_results: 3              # Web検索で取得する上位サイト数（1〜10）
  max_url_content_length: 2000       # URL取得時の本文最大文字数
  search_content_mode: "snippet"     # "snippet"=スニペットのみ / "full"=本文も取得
